# INSTRUCCIONES DE INSTALACIÓN:
# 1. Copia este archivo como secrets.toml
# 2. Completa con tus credenciales de Supabase
# 3. NUNCA hagas commit de secrets.toml al repositorio
# 
# OBTENER CREDENCIALES:
# https://supabase.com/dashboard/project/_/settings/api
#
# ========================================

# Configuración de Supabase
SUPABASE_URL = "https://TU_PROJECT_ID.supabase.co"
SUPABASE_KEY = "tu_anon_public_key_aqui"

# ========================================
# NOTAS DE SEGURIDAD:
# ========================================
# - Usar SOLO la anon public key (no service_role key)
# - Nunca compartir o subir credenciales reales
# - En Streamlit Cloud: configurar en Settings > Secrets
# - En producción: usar variables de entorno del sistema
# ========================================
